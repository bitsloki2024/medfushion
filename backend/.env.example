# Copy this file to .env and fill in your keys
# None of these are required — the app runs without them using built-in fallbacks

# Optional: Groq LLM key for richer Cosmo AI responses (free at console.groq.com)
GROQ_API_KEY=gsk_your_key_here

# Optional: Anthropic Claude key (takes priority over Groq if set)
ANTHROPIC_API_KEY=sk-ant-your_key_here

# Set automatically by Railway/Render — do not set manually in production
# PORT=8000
# API_BASE_URL=http://localhost:8000
